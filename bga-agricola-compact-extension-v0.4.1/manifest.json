{
  "manifest_version": 3,
  "name": "BGA Agricola Compact Panel",
  "version": "0.12.35",
  "description": "Removes the duplicate compact status line and restores the native right-side player list while keeping log bottom aligned.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://boardgamearena.com/*/agricola*",
    "https://*.boardgamearena.com/*/agricola*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://boardgamearena.com/*/agricola*",
        "https://*.boardgamearena.com/*/agricola*"
      ],
      "js": [
        "content/00_bootstrap.js",
        "content/10_settings.js",
        "content/20_dom-query.js",
        "content/30_panel-shell.js",
        "content/40_resource-row.js",
        "content/50_farm-view.js",
        "content/60_card-columns.js",
        "content/70_interactions.js",
        "content/80_observer.js",
        "content/85_original-ui-compact.js",
        "content/90_debug.js"
      ],
      "css": [
        "styles/base.css",
        "styles/panel.css",
        "styles/resource-row.css",
        "styles/farm-view.css",
        "styles/card-columns.css",
        "styles/debug.css",
        "styles/original-ui.css"
      ],
      "run_at": "document_idle"
    }
  ]
}