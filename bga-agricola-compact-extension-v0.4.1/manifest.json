{
  "manifest_version": 3,
  "name": "BGA PlayAgricolaOnline Mode",
  "version": "1.0.2",
  "description": "Compacts BGA Agricola with original-DOM board, hand, action-card, and log layouts.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://boardgamearena.com/*/agricola*",
    "https://*.boardgamearena.com/*/agricola*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://boardgamearena.com/*/agricola*",
        "https://*.boardgamearena.com/*/agricola*"
      ],
      "all_frames": true,
      "js": [
        "content/00_bootstrap.js",
        "content/10_settings.js",
        "content/20_dom-query.js",
        "content/30_panel-shell.js",
        "content/50_farm-view.js",
        "content/60_card-columns.js",
        "content/70_interactions.js",
        "content/80_observer.js",
        "content/original-ui/layout-models.js",
        "content/original-ui/style-state.js",
        "content/original-ui/preferences.js",
        "content/original-ui/card-text.js",
        "content/original-ui/action-cards-layout.js",
        "content/original-ui/hand-layout.js",
        "content/85_original-ui-compact.js",
        "content/90_debug.js"
      ],
      "css": [
        "styles/base.css",
        "styles/panel.css",
        "styles/farm-view.css",
        "styles/card-columns.css",
        "styles/debug.css",
        "styles/original-ui.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
